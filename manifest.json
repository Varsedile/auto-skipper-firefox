{
  "manifest_version": 2,
  "name": "Auto Skipper for Firefox",
  "version": "1.0.1",
  "description": "Automatically skips Netflix intros, recaps, and credits.",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.netflix.com/*",
        "*://*.hotstar.com/*"
      ],
      "js": [
        "src/content.js"
      ]
    }
  ],
  "browser_action": {
    "default_icon": {
      "48": "src/icons/icon.png"
    },
    "default_title": "Netflix Auto Skipper",
    "default_popup": "src/popup/popup.html"
  },
  "icons": {
    "48": "src/icons/icon.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "test@test.com",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
